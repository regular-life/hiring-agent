# LLM Provider Configuration
# Options: "ollama", "gemini", "openrouter", "nvidia", "groq", or "router" (fault-tolerant fallback router)
LLM_PROVIDER=router

# Default model to use (when using a single provider)
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
# For OpenRouter: "google/gemini-2.5-flash", "meta-llama/llama-3-8b-instruct:free", etc.
# For Nvidia NIM: "meta/llama-3.1-8b-instruct", etc.
# For Groq: "llama-3.3-70b-versatile", etc.
DEFAULT_MODEL=gemma3:4b

# Google Gemini API Key and Model (required if using Gemini or router)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# OpenRouter API Key and Model (required if using OpenRouter or router)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openrouter/owl-alpha

# Nvidia NIM API Key and Model (required if using Nvidia NIM or router)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=stepfun-ai/step-3.7-flash

# Groq API Key and Model (required if using Groq or router)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3.6-27b

# Ollama Model override (optional, used as fallback or in router mode)
OLLAMA_MODEL=gemma3:4b
